pip install pytrends plotly


import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import plotly.express as px
from pytrends.request import TrendReq





pytrends = TrendReq(hl = 'en-US', tz = 360)
keyword = "Artificial intelligence"





pytrends.build_payload([keyword], cat = 0, timeframe = 'today 12-m', geo='', gprop = '')





region_data = pytrends.interest_by_region()
region_data = region_data.sort_values(by = keyword, ascending = False).head(15)


plt.figure(figsize = (10,6))
sns.barplot(x = region_data[keyword], y = region_data.index, palette = "Blues_d")
plt.xlabel("Interest")
plt.ylabel("Countries")
plt.title(f"Top Countries Searching for '{keyword} ")
plt.show()





region_data = region_data.reset_index(drop=True)
fig = px.choropleth(region_data,
                    locations = 'geoName',
                    locationmode = 'country names',
                    color = keyword,
                    title = f"search Interest for '{keyword}' by Country",
                    color_continuous_scale = 'Blues')
fig.show()





time_df = pytrends.interest_over_time()


plt.figure(figsize=(12,6))
plt.plot(time_df.index, time_df[keyword], marker = 'o', color = 'purple')
plt.title(f"search interst over time '{keyword}' ")
plt.xlabel("Date")
plt.ylabel("Interest")
plt.grid(True)
plt.show()





key_list = ["cloud computing", "data science", "machine learning"]
pytrends.build_payload(key_list, cat=0, timeframe = 'today 12-m', geo = '',gprop='')


compare_df = pytrends.interest_over_time()

plt.figure(figsize=(12,6))
for kw in key_list:
    plt.plot(compare_df.index, compare_df[kw], label = kw)

plt.title("Keyword comparision over time")
plt.xlabel("Date")
plt.ylabel("Interest")
plt.legend()
plt.grid(True)



